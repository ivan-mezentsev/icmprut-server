# ---------------------------------------------------------------------------
# icmprut-server example environment file.
#
# Copy this file to ".env" (referenced by docker-compose.yaml) and adjust the
# values for your deployment:
#
#     cp .env_example .env
#
# Lines starting with "#" are comments. Do NOT wrap values in quotes.
# ---------------------------------------------------------------------------

# --- Runtime ----------------------------------------------------------------

# Node runtime mode. Keep "production" for container deployments.
NODE_ENV=production

# Container timezone (IANA name), e.g. UTC, Europe/Berlin, America/New_York.
TZ=UTC

# --- HTTP listener ----------------------------------------------------------

# Address and port the UI/API server binds to inside the container.
ICMPRUT_SERVER_HOST=0.0.0.0
ICMPRUT_SERVER_PORT=3089

# --- Upstream InfluxDB 3 ----------------------------------------------------

# Base URL of the InfluxDB 3 Core instance that holds the ping data.
ICMPRUT_INFLUXDB_URL=http://influxdb.example.com:8181

# InfluxDB 3 API token with read access. The token stays server-side and is
# never exposed to the browser.
ICMPRUT_INFLUXDB_TOKEN=apiv3_replace_with_your_real_token

# Database name.
ICMPRUT_INFLUXDB_DB=icmprut

# Per-request upstream timeout in milliseconds.
ICMPRUT_INFLUXDB_TIMEOUT_MS=30000

# --- Query cache / coalescing ----------------------------------------------

# TTL for "live" queries whose range ends near now (ms).
ICMPRUT_CACHE_LIVE_TTL_MS=10000

# TTL for fully historical queries (ms).
ICMPRUT_CACHE_HISTORY_TTL_MS=300000

# Maximum number of cached entries (LRU eviction).
ICMPRUT_CACHE_MAX_ENTRIES=512

# Quantisation of "now" so near-simultaneous live requests share a cache key (ms).
ICMPRUT_CACHE_NOW_QUANT_MS=10000

# Settling window: ranges ending within this many ms of now keep the short live
# TTL, so late backfill from a previously-offline agent is never hidden (ms).
ICMPRUT_CACHE_SETTLE_MS=600000

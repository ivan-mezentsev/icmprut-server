{
  "name": "icmprut-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node --watch server/index.js",
    "dev:web": "vite --host 0.0.0.0 --port 3089",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3089",
    "start": "node server/index.js"
  },
  "dependencies": {
    "d3-force": "^3.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "vite": "^8.0.16"
  }
}